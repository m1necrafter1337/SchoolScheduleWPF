<Page x:Class="SchoolSchedule.Views.SchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{DynamicResource CardBg}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
            Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtDayName" Grid.Column="0"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}"
                   VerticalAlignment="Center"/>
                <ProgressBar x:Name="BusyIndicator" Grid.Column="1"
                     IsIndeterminate="True" Width="80" Height="6"
                     Visibility="Collapsed" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- Кнопки дней -->
        <Border Grid.Row="1" Background="{DynamicResource AppBg}" Padding="8,6">
            <StackPanel x:Name="DayButtonsPanel" Orientation="Horizontal"/>
        </Border>

        <!-- Сетка + боковая панель -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="SidePanelCol" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Сетка БЕЗ скролла, растянута на всю область -->
            <Grid x:Name="ScheduleGrid" Grid.Column="0" Margin="4"/>

            <!-- Боковая панель -->
            <Border Grid.Column="1" x:Name="SidePanel"
              Background="{DynamicResource CardBg}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1,1,0,0"
              Margin="0,0,0,0"     
              Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1A4A90D9" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="PanelTitle" Grid.Column="0"
                         FontSize="13" FontWeight="Bold"
                         Foreground="#4A90D9" VerticalAlignment="Center"
                         TextWrapping="Wrap"/>
                            <Button Grid.Column="1" Content="✕"
                      Width="26" Height="26"
                      Background="Transparent" BorderThickness="0"
                      Foreground="#888888" FontSize="14" Cursor="Hand"
                      Click="OnClosePanelClicked"/>
                        </Grid>
                    </Border>

                    <!-- Скролл без видимого бара -->
                    <ScrollViewer Grid.Row="1"
                        VerticalScrollBarVisibility="Hidden">
                        <StackPanel x:Name="AssignmentsList" Margin="6"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
