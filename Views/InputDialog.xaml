<Window x:Class="SchoolSchedule.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод" SizeToContent="Height" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F5F5">
    <StackPanel Margin="20">
        <TextBlock x:Name="Prompt" FontSize="14" Margin="0,0,0,8"
               Foreground="#1A1A1A" TextWrapping="Wrap"/>
        <TextBox x:Name="InputBox" FontSize="14" Padding="6"
             BorderBrush="#BBCCEE" BorderThickness="1"
             KeyDown="OnKeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="ОК"     Click="OkBtn_Click"     Width="80" Padding="0,7"
              Background="#4A90D9" Foreground="White" BorderThickness="0"
              Cursor="Hand" Margin="0,0,8,0"/>
            <Button Content="Отмена" Click="CancelBtn_Click" Width="80" Padding="0,7"
              Background="#888888" Foreground="White" BorderThickness="0"
              Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>
