<Window x:Class="SchoolSchedule.Views.SelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор" Height="380" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="Prompt" Grid.Row="0" FontSize="14" Margin="0,0,0,8"
               Foreground="#1A1A1A" TextWrapping="Wrap"/>

        <ListBox x:Name="ItemsList" Grid.Row="1"
             BorderBrush="#BBCCEE" FontSize="14"
             MouseDoubleClick="OnDoubleClick"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="ОК"     Click="OkBtn_Click"     Width="80" Padding="0,7"
              Background="#4A90D9" Foreground="White" BorderThickness="0"
              Cursor="Hand" Margin="0,0,8,0"/>
            <Button Content="Отмена" Click="CancelBtn_Click" Width="80" Padding="0,7"
              Background="#888888" Foreground="White" BorderThickness="0"
              Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
