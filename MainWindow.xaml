<Window x:Class="SchoolSchedule.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SchoolSchedule" Height="700" Width="1100"
        MinHeight="500" MinWidth="700"
        Background="{DynamicResource AppBg}"
        Icon="Assets/appicon.ico">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" GlassFrameThickness="1" UseAeroCaptionButtons="True"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Навигационная панель -->
        <Border Grid.Row="0" Background="{DynamicResource NavBg}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel x:Name="NavPanel" Orientation="Horizontal" Margin="8,4">
                <Button x:Name="BtnSchedule"  Content="📅  Расписание"  Click="NavBtn_Click" Tag="0"
                Style="{StaticResource NavButtonStyle}" Margin="0,0,4,0"/>
                <Button x:Name="BtnReference" Content="📚  Справочники" Click="NavBtn_Click" Tag="1"
                Style="{StaticResource NavButtonStyle}" Margin="0,0,4,0"/>
                <Button x:Name="BtnSettings"  Content="⚙️  Настройки"   Click="NavBtn_Click" Tag="2"
                Style="{StaticResource NavButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Контентная область -->
        <Frame x:Name="MainFrame" Grid.Row="1"
           NavigationUIVisibility="Hidden"
           Background="{DynamicResource AppBg}"/>
    </Grid>
</Window>
